{
  "routes": [
    {
      "route": "/",
      "redirect": "/nl/",
      "statusCode": 302
    },
    {
      "route": "/nl/",
      "rewrite": "/nl/index.html"
    },
    {
      "route": "/en/",
      "rewrite": "/en/index.html"
    },
    {
      "route": "/nl/customers/*",
      "rewrite": "/nl/index.html"
    },
    {
      "route": "/en/customers/*",
      "rewrite": "/en/index.html"
    },
    {
      "route": "/customers/*",
      "rewrite": "/nl/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/nl/index.html"
  }
}
